DNIT_RUC_URL=https://www.dnit.gov.py/en/web/portal-institucional/listado-de-ruc-con-sus-equivalencias

# Recomendado: reutilizar DATABASE_URL del mismo .env que usa ventax-facturacion-simple.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ventax

# Opcional: si se define DB_* tiene prioridad sobre DATABASE_URL.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ventax
DB_USER=postgres
DB_PASSWORD=postgres

DATA_DIR=./data
IMPORT_BATCH_SIZE=5000
DNIT_CRON_DAY=05
DNIT_CRON_HOUR=3
DNIT_CRON_MINUTE=0
