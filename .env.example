NODE_ENV=development
PORT=8080
API_BASE_PATH=/api/v1
APP_ORIGIN=http://localhost:8092
BACKOFFICE_ORIGIN=http://localhost:8092
FRONTEND_HTTP_PORT=8092
API_HTTP_PORT=8091
POSTGRES_HOST_PORT=5433

DATABASE_URL=postgres://facturacion_simple:facturacion_simple@localhost:5432/facturacion_simple

JWT_ACCESS_SECRET=<secret>
JWT_REFRESH_SECRET=<secret>
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

FE_API_BASE_URL=https://fe-api.ventax.app/fcws
FE_API_KEY=<x-api-key>
FE_API_TIMEOUT_MS=20000
FE_API_ENV=test
FE_GATEWAY_MODE=mock
FE_SEND_EMISSION_PROFILE_CODE=false
FE_SERVICE_NUMBERING=true
FE_OUTBOX_WORKER_ENABLED=true
FE_OUTBOX_WORKER_INTERVAL_MS=5000

PUBLIC_APP_BASE_URL=https://factura.ventax.app

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

BACKUP_CRON_HOUR=2
BACKUP_CRON_MINUTE=15
BACKUP_KEEP_RECENT_DAYS=7
BACKUP_KEEP_EXTENDED_DAYS=30

SMOKE_BASE_URL=http://localhost:8092
SMOKE_API_BASE_URL=http://localhost:8092/api/v1
SMOKE_USERNAME=<smoke-username>
SMOKE_PASSWORD=<smoke-password>

FE_SMOKE_RUN=NO
FE_SMOKE_DRY_RUN=YES
FE_SMOKE_FACTURA_FIXTURE=.local/fe-smoke/factura-awapura-contado.json
FE_SMOKE_ID=<optional-fixed-idempotency-key>

ONBOARDING_SMOKE_CLIENTE_TIPO=CI
ONBOARDING_SMOKE_CLIENTE_DOCUMENTO=492019
ONBOARDING_SMOKE_CLIENTE_RAZON_SOCIAL=Roberto Saldivar
ONBOARDING_SMOKE_CLIENTE_DIRECCION=Asuncion
ONBOARDING_SMOKE_CLIENTE_TELEFONO=021000000
ONBOARDING_SMOKE_ITEM_DESCRIPCION=Servicio de prueba onboarding
ONBOARDING_SMOKE_ITEM_PRECIO_UNITARIO=100000
ONBOARDING_SMOKE_ITEM_IVA_TIPO=IVA_10
ONBOARDING_SMOKE_CONDICION_VENTA=CONTADO
