COMPOSE_PROJECT_NAME=ventax-facturacion-simple

NODE_ENV=production
PORT=8080
API_BASE_PATH=/api/v1
APP_ORIGIN=https://staging-factura.ventax.app
BACKOFFICE_ORIGIN=https://staging-factura.ventax.app
PUBLIC_APP_BASE_URL=https://staging-factura.ventax.app

FRONTEND_HTTP_PORT=8092
API_HTTP_PORT=8091
POSTGRES_HOST_PORT=5433

POSTGRES_DB=facturacion_simple
POSTGRES_USER=facturacion_simple
POSTGRES_PASSWORD=facturacion_simple
DATABASE_URL=postgres://facturacion_simple:facturacion_simple@ventax-facturacion-simple-postgres-1:5432/facturacion_simple

JWT_ACCESS_SECRET=<secret-largo-staging>
JWT_REFRESH_SECRET=<secret-largo-staging>
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

FE_GATEWAY_MODE=real
FE_DOCKER_NETWORK=fe-test_default
FE_API_BASE_URL=http://fe-test-api-1:8080/fcws
FE_API_KEY=<x-api-key-staging>
FE_API_ENV=test
FE_API_TIMEOUT_MS=20000
FE_SEND_EMISSION_PROFILE_CODE=true
FE_SERVICE_NUMBERING=true
FE_OUTBOX_WORKER_ENABLED=true
FE_OUTBOX_WORKER_INTERVAL_MS=5000

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

BACKUP_CRON_HOUR=2
BACKUP_CRON_MINUTE=15
BACKUP_KEEP_RECENT_DAYS=7
BACKUP_KEEP_EXTENDED_DAYS=30

SMOKE_BASE_URL=https://staging-factura.ventax.app
SMOKE_API_BASE_URL=https://staging-factura.ventax.app/api/v1
SMOKE_USERNAME=<smoke-username-staging>
SMOKE_PASSWORD=<smoke-password-staging>

ONBOARDING_SMOKE_CLIENTE_TIPO=CI
ONBOARDING_SMOKE_CLIENTE_DOCUMENTO=492019
ONBOARDING_SMOKE_CLIENTE_RAZON_SOCIAL=Roberto Saldivar
ONBOARDING_SMOKE_CLIENTE_DIRECCION=Asuncion
ONBOARDING_SMOKE_CLIENTE_TELEFONO=021000000
ONBOARDING_SMOKE_ITEM_DESCRIPCION=Servicio de prueba onboarding staging
ONBOARDING_SMOKE_ITEM_PRECIO_UNITARIO=100000
ONBOARDING_SMOKE_ITEM_IVA_TIPO=IVA_10
ONBOARDING_SMOKE_CONDICION_VENTA=CONTADO
