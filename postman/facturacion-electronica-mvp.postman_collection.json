              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/fcws/factura",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "fcws",
                "factura"
              ]
            },
            "description": "Ejemplo canonico de integracion para clientes externos. El numero sugerido se envia solo como referencia; la numeracion fiscal online pertenece al servicio."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 o 409', function () {",
                  "  pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.document_id) pm.collectionVariables.set('last_document_id', json.document_id);",
                  "if (json.cdc) pm.collectionVariables.set('last_cdc', json.cdc);",
                  "if (json.nro_factura) pm.collectionVariables.set('last_nro_factura', json.nro_factura);"
                ]
              }
            }
          ],
          "response": []
        },
