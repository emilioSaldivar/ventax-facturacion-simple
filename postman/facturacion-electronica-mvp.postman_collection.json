{
  "info": {
    "name": "Facturacion Electronica MVP",
    "description": "Collection Postman parametrizada para el MVP de facturacion electronica. La autenticacion real del servicio actual es por API_KEY; el request 'Bootstrap Token' copia {{api_key}} a {{bearer_token}} para usar Authorization: Bearer en el resto de endpoints. Los ejemplos de emision usan un contrato neutral para clientes externos: el cliente puede enviar numero sugerido y referencia externa, pero la numeracion fiscal online pertenece al servicio.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearer_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('bearer_token') && pm.environment.get('api_key')) {",
          "  pm.collectionVariables.set('bearer_token', pm.environment.get('api_key'));",
          "}",
          "if (!pm.collectionVariables.get('x_api_key') && pm.environment.get('api_key')) {",
          "  pm.collectionVariables.set('x_api_key', pm.environment.get('api_key'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Bootstrap Token (API_KEY -> Bearer)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/fcws/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "fcws",
                "health"
              ]
            },
            "description": "No existe endpoint de login real en este repo. Este request hace bootstrap de autenticacion copiando {{api_key}} a las variables {{bearer_token}} y {{x_api_key}} para que el resto de requests queden listos."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health responde 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var apiKey = pm.environment.get('api_key');",
                  "if (!apiKey) {",
                  "  throw new Error('Falta api_key en el environment');",
                  "}",
                  "pm.collectionVariables.set('bearer_token', apiKey);",
                  "pm.collectionVariables.set('x_api_key', apiKey);",
                  "console.log('bearer_token actualizado desde api_key');"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
